# Copy to /Users/vinit/Documents/work/robinhood/.env and fill in.

# ============================================================================
# BROKER SELECTION
# ============================================================================
# alpaca = use Alpaca (week 1 paper trading + week 2+ live)
# robinhood = use robin_stocks (after Alpaca validation period)
BROKER=alpaca

# ============================================================================
# ALPACA (https://app.alpaca.markets)
# ============================================================================
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview (paper)
# or https://app.alpaca.markets/live/dashboard/overview (live)
ALPACA_KEY_ID=
ALPACA_SECRET=
# paper: https://paper-api.alpaca.markets
# live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================================================
# FINNHUB (https://finnhub.io)
# ============================================================================
# Free tier: 60 req/min, covers earnings calendar + news + sentiment.
FINNHUB_KEY=

# ============================================================================
# DISCORD APPROVAL BOT
# ============================================================================
# Setup: discord.com/developers -> New Application -> Bot -> copy token.
# Invite bot to your private server with Read/Send Messages + Add Reactions perms.
DISCORD_TOKEN=
# Your Discord user ID (right-click your name w/ Developer Mode on -> Copy ID).
DISCORD_USER_ID=
# Channel ID where the bot posts proposals (right-click channel -> Copy ID).
DISCORD_CHANNEL_ID=

# Robinhood support deferred (credentials too sensitive to embed in cloud routine prompts).
# Alpaca-only for cloud deployment.
